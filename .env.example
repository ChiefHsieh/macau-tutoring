NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 客服中心：所有用户点「客服中心」会打开与这位用户的私信线程（Supabase Auth 的 user id，与 public.users.id 一致）。
# 对应账号需在应用内注册；建议与下方邮箱为同一账号。生产环境务必在 Netlify / Vercel 环境变量中填写。
SUPPORT_MANAGER_USER_ID=

# 注册后无需邮箱验证、立即拿到 Session：
# Supabase Dashboard → Authentication → Providers → Email
# 关闭「Confirm email」（并保存）。纯控制台配置，无法仅靠本仓库代码关闭。

# Landing "Contact" section (public; safe to expose in the browser bundle)
NEXT_PUBLIC_CONTACT_WECHAT=
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_HOURS=

# Optional social links (footer icons; leave empty to show disabled gray icons)
NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=
NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=
NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=
